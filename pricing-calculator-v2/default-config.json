    { "id": "i2a-auto-tactical",         "label": "I2A — Autonomous + Tactical",             "channels": ["auto-sourcing", "tactical"],                                               "weightStrategy": "complexity", "group": "i2a", "volumeBasis": { "refSpend": 750, "refVolume": 1000, "exponent": 0.60 } },
    { "id": "i2a-auto-tactical-strategic","label": "I2A — Autonomous + Tactical + Strategic","channels": ["auto-sourcing", "tactical", "strategic"],                                  "weightStrategy": "complexity", "group": "i2a", "volumeBasis": { "refSpend": 750, "refVolume": 1150, "exponent": 0.60 } },
    { "id": "i2a-full",                  "label": "I2A — Full (all 4 sourcing)",             "channels": ["auto-sourcing", "auto-negotiation", "tactical", "strategic"],              "weightStrategy": "complexity", "group": "i2a", "volumeBasis": { "refSpend": 750, "refVolume": 1250, "exponent": 0.60 } },
    { "id": "p2p-catalog",               "label": "P2P — Catalog Only",                      "channels": ["catalog"],                                                                 "weightStrategy": "complexity", "group": "p2p", "volumeBasis": { "refSpend": 750, "refVolume": 3500, "exponent": 0.75 } },
    { "id": "p2p-catalog-sspo",          "label": "P2P — Catalog + Self-Service PO",         "channels": ["catalog", "self-service-po"],                                              "weightStrategy": "complexity", "group": "p2p", "volumeBasis": { "refSpend": 750, "refVolume": 4000, "exponent": 0.75 } },
    { "id": "p2p-transactional",         "label": "P2P — Transactional (Catalog+SSPO+RC+Non-PO)","channels": ["catalog", "self-service-po", "rc-invoice", "non-po-spend"],             "weightStrategy": "complexity", "group": "p2p", "volumeBasis": { "refSpend": 750, "refVolume": 5000, "exponent": 0.75 } },
    { "id": "p2p-full",                  "label": "P2P — Full (all 5 P2P)",                  "channels": ["catalog", "self-service-po", "contract-fw", "rc-invoice", "non-po-spend"], "weightStrategy": "complexity", "group": "p2p", "volumeBasis": { "refSpend": 750, "refVolume": 6000, "exponent": 0.75 } }
