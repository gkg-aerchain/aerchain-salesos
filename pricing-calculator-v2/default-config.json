{
  "version": 2,
  "label": "Aerchain Standard Pricing v2",

  "feeStructure": {
    "platformPct": 0.45,
    "workflowPct": 0.55
  },

  "spendTiers": [
    { "spend": 100,  "fee": 100  },
    { "spend": 250,  "fee": 225  },
    { "spend": 500,  "fee": 400  },
    { "spend": 750,  "fee": 575  },
    { "spend": 1000, "fee": 750  }
  ],
  "bpsBelow100M": 10.0,
  "bpsAbove1B": 7.0,
  "baselineFloorK": 100,

  "volumeDiscount": {
    "enabled": true,
    "floor": 100,
    "cap": 3000,
    "maxDiscount": 0.70,
    "exponent": 0.70
  },

  "implSpendScaling": {
    "enabled": true,
    "refSpend": 750,
    "exponent": 0.50,
    "minMult": 1.0,
    "maxMult": 3.0
  },

  "products": {
    "intake-to-award":  { "label": "Intake to Award",  "sub": "Autonomous & Strategic Sourcing", "multiplier": 1.00, "base": true },
    "procure-to-pay":   { "label": "Procure to Pay",   "sub": "PO, Invoice, Payments",           "multiplier": 0.75 }
  },

  "entityTiers": [
    { "label": "1",    "min": 1,  "max": 1,   "multiplier": 1.00 },
    { "label": "2-3",  "min": 2,  "max": 3,   "multiplier": 1.15 },
    { "label": "4-10", "min": 4,  "max": 10,  "multiplier": 1.30 },
    { "label": "10+",  "min": 11, "max": 999, "multiplier": 1.50 }
  ],

  "clientTiers": {
    "mid-market":       { "label": "Mid-Market",       "minSpend": 0,   "maxSpend": 250,  "powerUsers": 15,  "lightUsers": 60,   "entities": 1,  "implMultiplier": 0.60, "implDuration": "3-4 months" },
    "enterprise":       { "label": "Enterprise",       "minSpend": 250, "maxSpend": 750,  "powerUsers": 30,  "lightUsers": 180,  "entities": 2,  "implMultiplier": 0.85, "implDuration": "4-6 months" },
    "large-enterprise": { "label": "Large Enterprise", "minSpend": 750, "maxSpend": 99999,"powerUsers": 50,  "lightUsers": 400,  "entities": 11, "implMultiplier": 1.00, "implDuration": "6-8 months" }
  },

  "channels": [
    { "id": "catalog",           "label": "Catalog",               "weight": 0.06, "defaultTxnPct": 0.30, "complexity": 2  },
    { "id": "self-service-po",   "label": "Self-Service PO",       "weight": 0.02, "defaultTxnPct": 0.10, "complexity": 3  },
    { "id": "contract-fw",       "label": "Contract Framework",    "weight": 0.03, "defaultTxnPct": 0.05, "complexity": 8  },
    { "id": "rc-invoice",        "label": "RC Invoice",            "weight": 0.04, "defaultTxnPct": 0.05, "complexity": 4  },
    { "id": "non-po-spend",      "label": "Non-PO Spend",          "weight": 0.01, "defaultTxnPct": 0.05, "complexity": 4  },
    { "id": "auto-sourcing",     "label": "Autonomous Sourcing",   "weight": 0.15, "defaultTxnPct": 0.20, "complexity": 21 },
    { "id": "auto-negotiation",  "label": "Autonomous Negotiation","weight": 0.09, "defaultTxnPct": 0.05, "complexity": 15 },
    { "id": "tactical",          "label": "Tactical Sourcing",     "weight": 0.23, "defaultTxnPct": 0.15, "complexity": 28 },
    { "id": "strategic",         "label": "Strategic Sourcing",    "weight": 0.37, "defaultTxnPct": 0.05, "complexity": 33 }
  ],

  "channelPresets": [
    { "id": "full-suite",                "label": "Full Suite (all channels)",               "channels": null,                                                                        "weightStrategy": "manual",     "group": "combined", "volumeBasis": { "refSpend": 750, "refVolume": 7000, "exponent": 0.70 } },
    { "id": "sourcing-led",              "label": "Sourcing-Led (I2A only)",                 "channels": ["auto-sourcing", "auto-negotiation", "tactical", "strategic"],              "weightStrategy": "complexity", "group": "combined", "volumeBasis": { "refSpend": 750, "refVolume": 1250, "exponent": 0.60 } },
    { "id": "p2p-led",                   "label": "P2P-Led (P2P only)",                      "channels": ["catalog", "self-service-po", "contract-fw", "rc-invoice", "non-po-spend"], "weightStrategy": "complexity", "group": "combined", "volumeBasis": { "refSpend": 750, "refVolume": 6000, "exponent": 0.75 } },
